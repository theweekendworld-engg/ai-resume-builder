NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# PostgreSQL Database (for Resume model)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resume_builder?schema=public

# OpenAI API Key + model config
OPENAI_API_KEY=sk-...

# Optional global fallback model
OPENAI_MODEL=gpt-4o-mini
# Optional general-purpose override (used by non-specialized calls)
OPENAI_MODEL_GENERAL=gpt-4o-mini
# Per-operation model selection (recommended tiering)
OPENAI_MODEL_JD_PARSE=gpt-4o-mini
OPENAI_MODEL_PARAPHRASE=gpt-4o
OPENAI_MODEL_ATS_SCORE=gpt-4o-mini
OPENAI_MODEL_ASSEMBLY=gpt-4o
OPENAI_MODEL_CLAIM_VALIDATION=gpt-4o-mini

OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_SIZE=1536

# Admin dashboard access (comma-separated Clerk user IDs)
ADMIN_USER_IDS=

# Monthly per-user usage limits (set <= 0 to disable)
USAGE_MAX_MONTHLY_TOKENS_PER_USER=300000
USAGE_MAX_MONTHLY_COST_USD_PER_USER=10

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333

# Redis (rate limit/cache/local async coordination)
REDIS_URL=redis://localhost:6379

# Upstash Redis REST (optional; for serverless rate limiting on Vercel)
# Get from https://console.upstash.com
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Telegram (Phase 5)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=
# Optional: secret for internal async processing endpoint.
# If not set, TELEGRAM_WEBHOOK_SECRET is reused.
TELEGRAM_INTERNAL_SECRET=

# Resume import (PDF parsing)
OPENAI_MODEL_RESUME_PARSE=gpt-4o-mini
RESUME_IMPORT_MAX_FILE_SIZE_KB=5000

# Phase 8: Smart reuse + resilient PDF storage
RESUME_REUSE_ENABLED=true
RESUME_REUSE_MIN_ATS_SCORE=80
RESUME_REUSE_SIMILARITY_THRESHOLD=0.65

# local | blob
PDF_STORAGE_MODE=local
# Relative to project root when using local mode
PDF_STORAGE_LOCAL_DIR=.storage/generated-pdfs
# Optional public base URL used to construct links for local files
PDF_STORAGE_PUBLIC_BASE_URL=
# Feature flag for fetching already-stored PDFs before recompiling
PDF_STORAGE_ENABLE_FETCH=true

# Feature flags
FEATURE_INLINE_REWRITE_V2=true
FEATURE_JD_KEYWORD_MATCH_HINTS=true
FEATURE_TELEGRAM_SEND_PDF_DOCUMENT=true
FEATURE_TELEGRAM_ASYNC_PROCESSING=true
